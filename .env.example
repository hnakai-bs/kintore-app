# Firebase（Web アプリの設定を Console からコピー）
# 設定するとメール／パスワード認証が必須になります。未設定の場合は従来どおり認証なしで動きます。

NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=

# --- 以下は Nuxt では使いません（npm run admin:create 用）---
# Firebase Console → サービス アカウント → 秘密鍵 JSON（nuxt-app からの相対パス可）
# GOOGLE_APPLICATION_CREDENTIALS=./your-project-firebase-adminsdk-xxxxx.json
# パスワードを .env に置く場合（第2引数不要）:
# ADMIN_CREATE_PASSWORD=
